# Normalize line endings so commits don't churn on CRLF/LF differences.
* text=auto eol=lf
*.html text eol=lf
*.css  text eol=lf
*.js   text eol=lf
*.md   text eol=lf

# Windows helper scripts keep CRLF
*.ps1  text eol=crlf
*.cmd  text eol=crlf
*.bat  text eol=crlf

# Binary assets — never normalize (would corrupt them)
*.png  binary
*.ico  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
